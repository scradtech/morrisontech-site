---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const services = [
  {
    title: 'Website Design & Development',
    description: `Every Morrisontech site is built from scratch to suit your business — no templates, no shortcuts. We use Astro for fast, content-focused business sites and Next.js when you need a web application, e-commerce, or user accounts. All styling is done with Tailwind CSS for pixel-perfect, responsive results on every screen size.`,
    includes: [
      'Custom design tailored to your brand',
      'Mobile-first, responsive layout',
      'Basic on-page SEO (meta titles, descriptions, structured HTML)',
      'Contact form integration',
      'Fast page load times — no unnecessary bloat',
    ],
  },
  {
    title: 'AI-Powered Development',
    description: `Morrisontech uses the latest AI development tools — including Claude Code — throughout every build. This isn't about cutting corners. It's about moving faster and delivering more value for your budget. You get a professionally built site in less time, at a lower cost, with the same attention to quality.\n\nWe're transparent about our tooling because we see it as a competitive advantage for you, not something to hide.`,
    includes: [
      'Faster project turnaround than traditional agencies',
      'Lower development cost passed on to the client',
      'Same quality standards — AI assists, humans review everything',
      'Modern stack that is easy to maintain and extend',
    ],
  },
  {
    title: 'Hosting & Maintenance',
    description: `Once your site is built, we handle the infrastructure. Each site runs in its own Docker container on a Linux server, routed through Nginx Proxy Manager. This keeps your site isolated, stable, and easy to update.\n\nWe handle ongoing maintenance — content updates, dependency updates, and quick-turnaround changes — so you can focus on running your business.`,
    includes: [
      'Docker container deployment per site',
      'Automated deployment pipeline',
      'Australian-based support',
      'Fast turnaround on content updates and changes',
    ],
  },
];
---

<Layout
  title="Services — Morrisontech"
  description="Website design, AI-powered development, and hosting for Australian businesses."
>
  <div class="bg-brand-dark pt-32 pb-16 text-center">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-white mb-4">Our Services</h1>
      <p class="text-gray-300 text-lg max-w-xl mx-auto">
        Everything you need to get your business online and keep it running.
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 space-y-20">
    {services.map((service, i) => (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div class={i % 2 === 1 ? 'md:order-last' : ''}>
          <h2 class="text-3xl font-bold text-brand-dark mb-4">{service.title}</h2>
          {service.description.split('\n\n').map(para => (
            <p class="text-gray-600 leading-relaxed mb-4">{para.trim()}</p>
          ))}
        </div>
        <div class="bg-brand-light rounded-xl p-8">
          <p class="text-sm font-semibold text-brand-dark uppercase tracking-wider mb-4">What's included</p>
          <ul class="space-y-3">
            {service.includes.map(item => (
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="text-brand-accent font-bold mt-0.5" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>

  <CTABanner />
</Layout>
