---
const services = [
  {
    icon: '🖥️',
    title: 'Website Design & Development',
    description: 'Custom websites built from scratch to suit your brand — professional, fast, and built to convert.',
  },
  {
    icon: '🛒',
    title: 'E-Commerce & Online Stores',
    description: 'Get your products online with a fully functional shop — secure payments, easy management, ready to sell.',
  },
  {
    icon: '🚀',
    title: 'Hosting & Maintenance',
    description: 'Reliable Australian hosting with ongoing support, fast updates, and no lock-in contracts.',
  },
];
---

<section class="bg-brand-light py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-brand-dark mb-3">What We Do</h2>
      <p class="text-gray-600 max-w-xl mx-auto">
        End-to-end website services for Australian businesses of every size.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map(service => (
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100 flex flex-col">
          <div class="text-4xl mb-4" aria-hidden="true">{service.icon}</div>
          <h3 class="text-xl font-semibold text-brand-dark mb-3">{service.title}</h3>
          <p class="text-gray-600 text-sm flex-1">{service.description}</p>
          <a
            href="/services"
            class="mt-6 text-brand-accent font-semibold text-sm hover:underline inline-flex items-center gap-1"
          >
            Learn more about {service.title} <span aria-hidden="true">→</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
