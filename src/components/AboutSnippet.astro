---
const differentiators = [
  'Fast delivery',
  'Australian-based',
  'Fixed pricing',
  'AI-powered tools',
];
---

<section class="bg-white py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold text-brand-dark mb-6">Built for Australian Businesses</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Based in Australia, Morrisontech combines IT expertise with modern AI tools
          to deliver professional websites faster than traditional agencies — without
          the overhead or the wait.
        </p>
        <a
          href="/about"
          class="text-brand-accent font-semibold hover:underline inline-flex items-center gap-1"
        >
          More about us <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {differentiators.map(item => (
          <div class="bg-brand-light rounded-lg p-5 text-center">
            <p class="text-brand-dark font-bold text-lg">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
